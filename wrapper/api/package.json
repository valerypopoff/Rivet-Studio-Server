{
  "name": "@self-hosted/rivet-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc",
    "start": "node dist/api/src/server.js",
    "runtime-libraries:managed:audit": "tsx src/scripts/runtime-library-managed-cleanup.ts audit",
    "runtime-libraries:managed:prune": "tsx src/scripts/runtime-library-managed-cleanup.ts prune",
    "workflow-storage:migrate": "tsx src/scripts/migrate-workflow-storage.ts migrate",
    "workflow-storage:verify": "tsx src/scripts/migrate-workflow-storage.ts verify",
    "workflow-storage:dangerously-nuke-managed-state": "tsx src/scripts/dangerously-nuke-managed-workflow-storage.ts",
    "test": "tsx --test src/tests/editor-bridge.test.ts src/tests/exec.test.ts src/tests/managed-backend-sql.test.ts src/tests/managed-execution-cache.test.ts src/tests/native-io.test.ts src/tests/plugin-installer.test.ts src/tests/runtime-libraries.test.ts src/tests/runtime-library-cleanup.test.ts src/tests/workflow-storage-config.test.ts src/tests/workflow-services.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.901.0",
    "@ironclad/rivet-node": "^1.25.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "minimatch": "^9.0.3",
    "pg": "^8.16.3",
    "tar": "^7.4.3",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.8.7",
    "@types/ws": "^8.18.1",
    "tsx": "^4.6.2",
    "typescript": "^5.7.3"
  }
}
