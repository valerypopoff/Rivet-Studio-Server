# VCS
.git
.gitignore
rivet/.git
rivet/.git/**
**/.git
**/.git/**

# Dependencies
**/node_modules

# Build artifacts
**/dist
**/build
**/.turbo
**/.cache
**/.vite

# Logs
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local runtime data
.data

# Python / misc caches
**/__pycache__
**/.DS_Store

# Keep Yarn metadata needed by rivet, but exclude heavy caches
rivet/.yarn/**
!rivet/.yarn/plugins/**
!rivet/.yarn/releases/**
!rivet/.yarn/patches/**
!rivet/.yarn/versions/**
rivet/.yarn/install-state.gz

# Local PnP artifacts generated during host dev
rivet/.pnp.cjs
rivet/.pnp.loader.mjs

# Editor/temp
.vscode
.idea
*.tmp
