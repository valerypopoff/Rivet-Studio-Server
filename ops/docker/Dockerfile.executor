# syntax=docker/dockerfile:1.7
FROM node:20-alpine AS builder

ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG ALL_PROXY
ARG NO_PROXY
ARG http_proxy
ARG https_proxy
ARG all_proxy
ARG no_proxy

ENV HTTP_PROXY=$HTTP_PROXY
ENV HTTPS_PROXY=$HTTPS_PROXY
ENV ALL_PROXY=$ALL_PROXY
ENV NO_PROXY=$NO_PROXY
ENV http_proxy=$http_proxy
ENV https_proxy=$https_proxy
ENV all_proxy=$all_proxy
ENV no_proxy=$no_proxy

RUN corepack enable && corepack prepare yarn@4.6.0 --activate

WORKDIR /app

COPY wrapper/bootstrap/proxy-bootstrap/ /opt/proxy-bootstrap/
RUN --mount=type=cache,target=/root/.npm npm --prefix /opt/proxy-bootstrap ci

COPY --from=rivet_source . /app/rivet/

WORKDIR /app/rivet
RUN --mount=type=cache,target=/root/.cache/yarn YARN_NODE_LINKER=node-modules YARN_CHECKSUM_BEHAVIOR=ignore yarn install --immutable || YARN_NODE_LINKER=node-modules YARN_CHECKSUM_BEHAVIOR=ignore yarn install

RUN YARN_NODE_LINKER=node-modules yarn workspace @ironclad/rivet-core run build
RUN YARN_NODE_LINKER=node-modules yarn workspace @ironclad/rivet-node run build

COPY wrapper/executor/build/bundle-executor.cjs /app/wrapper/executor/build/bundle-executor.cjs
RUN NODE_PATH=/app/rivet/node_modules node /app/wrapper/executor/build/bundle-executor.cjs

FROM node:20-alpine

ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG ALL_PROXY
ARG NO_PROXY
ARG http_proxy
ARG https_proxy
ARG all_proxy
ARG no_proxy

ENV HTTP_PROXY=$HTTP_PROXY
ENV HTTPS_PROXY=$HTTPS_PROXY
ENV ALL_PROXY=$ALL_PROXY
ENV NO_PROXY=$NO_PROXY
ENV http_proxy=$http_proxy
ENV https_proxy=$https_proxy
ENV all_proxy=$all_proxy
ENV no_proxy=$no_proxy

WORKDIR /app

COPY --from=builder /opt/proxy-bootstrap /opt/proxy-bootstrap
COPY --from=builder /app/rivet/packages/app-executor/bin/executor-bundle.cjs ./executor-bundle.cjs

RUN mkdir -p /root/.local/share/com.ironcladapp.rivet/plugins

ENV RIVET_RUNTIME_LIBRARIES_ROOT=/data/runtime-libraries
ENV RIVET_EXECUTOR_HOST=0.0.0.0
ENV RIVET_RUNTIME_PROCESS_ROLE=executor

EXPOSE 21889

CMD ["sh", "-lc", "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--import=/opt/proxy-bootstrap/bootstrap.mjs\" node executor-bundle.cjs --host \"${RIVET_EXECUTOR_HOST}\" --port 21889"]
