# syntax=docker/dockerfile:1.7
FROM node:24-alpine

ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG ALL_PROXY
ARG NO_PROXY
ARG http_proxy
ARG https_proxy
ARG all_proxy
ARG no_proxy

ENV HTTP_PROXY=$HTTP_PROXY
ENV HTTPS_PROXY=$HTTPS_PROXY
ENV ALL_PROXY=$ALL_PROXY
ENV NO_PROXY=$NO_PROXY
ENV http_proxy=$http_proxy
ENV https_proxy=$https_proxy
ENV all_proxy=$all_proxy
ENV no_proxy=$no_proxy

RUN apk add --no-cache git
RUN corepack enable && \
    corepack prepare yarn@4.6.0 --activate && \
    corepack prepare pnpm@10.18.3 --activate

# pnpm is used by plugin dependency installation.

WORKDIR /app

# Install proxy bootstrap for Node fetch/undici traffic.
COPY wrapper/bootstrap/proxy-bootstrap/ /opt/proxy-bootstrap/
RUN --mount=type=cache,target=/root/.npm npm --prefix /opt/proxy-bootstrap ci

COPY --from=rivet_source . rivet/
WORKDIR /app/rivet
RUN --mount=type=cache,target=/root/.cache/yarn YARN_NODE_LINKER=node-modules YARN_CHECKSUM_BEHAVIOR=ignore yarn install --immutable || YARN_NODE_LINKER=node-modules YARN_CHECKSUM_BEHAVIOR=ignore yarn install
RUN YARN_NODE_LINKER=node-modules yarn workspace @ironclad/rivet-core run build
RUN YARN_NODE_LINKER=node-modules yarn workspace @ironclad/rivet-node run build

WORKDIR /app
COPY scripts/link-rivet-node-package.mjs scripts/link-rivet-node-package.mjs

# Copy API source while preserving the wrapper layout expected by tsconfig.
COPY wrapper/api/ wrapper/api/
COPY wrapper/shared/ wrapper/shared/

WORKDIR /app/wrapper/api

# Install dependencies with a persistent BuildKit cache.
RUN --mount=type=cache,target=/root/.npm npm ci
RUN node /app/scripts/link-rivet-node-package.mjs

# Build the API so production runs compiled JavaScript instead of transpiling at startup.
RUN npm run build

# Create workspace and data directories
RUN mkdir -p /workspace /workflows /data/rivet-app/plugins /data/rivet-app/logs /data/runtime-libraries

ENV RIVET_RUNTIME_LIBRARIES_ROOT=/data/runtime-libraries
ENV RIVET_RUNTIME_PROCESS_ROLE=api

EXPOSE 80

CMD ["sh", "-lc", "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--import=/opt/proxy-bootstrap/bootstrap.mjs\" node --preserve-symlinks dist/api/src/server.js"]
