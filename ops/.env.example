# Host port for the reverse proxy
RIVET_PORT=8080

# OpenAI credentials (passed to API backend for env var shim)
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_ENDPOINT=

# Additional env vars to expose via get_environment_variable (comma-separated)
RIVET_ENV_ALLOWLIST=

# Additional shell commands to allow (comma-separated)
RIVET_SHELL_ALLOWLIST=

# Additional filesystem roots to allow access (comma-separated absolute paths)
RIVET_EXTRA_ROOTS=
