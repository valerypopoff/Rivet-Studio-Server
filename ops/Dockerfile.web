# syntax=docker/dockerfile:1.7
ARG NODE_IMAGE=node:20-alpine

FROM --platform=$BUILDPLATFORM ${NODE_IMAGE} AS builder

ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG ALL_PROXY
ARG NO_PROXY
ARG http_proxy
ARG https_proxy
ARG all_proxy
ARG no_proxy

ENV HTTP_PROXY=$HTTP_PROXY
ENV HTTPS_PROXY=$HTTPS_PROXY
ENV ALL_PROXY=$ALL_PROXY
ENV NO_PROXY=$NO_PROXY
ENV http_proxy=$http_proxy
ENV https_proxy=$https_proxy
ENV all_proxy=$all_proxy
ENV no_proxy=$no_proxy

RUN corepack enable && corepack prepare yarn@4.6.0 --activate

WORKDIR /app

# Copy upstream rivet source
COPY rivet/ rivet/

# Install upstream dependencies
WORKDIR /app/rivet
RUN --mount=type=cache,target=/root/.cache/yarn YARN_NODE_LINKER=node-modules YARN_CHECKSUM_BEHAVIOR=ignore yarn install --immutable || YARN_NODE_LINKER=node-modules YARN_CHECKSUM_BEHAVIOR=ignore yarn install

# Build upstream core + trivet (needed for wrapper frontend)
RUN YARN_NODE_LINKER=node-modules yarn workspace @ironclad/rivet-core run build
RUN YARN_NODE_LINKER=node-modules yarn workspace @ironclad/trivet run build

# Copy wrapper source
WORKDIR /app
COPY wrapper/ wrapper/

# Install wrapper web dependencies
WORKDIR /app/wrapper/web
RUN --mount=type=cache,target=/root/.npm npm install --legacy-peer-deps

# Build wrapper frontend
ARG VITE_RIVET_DEBUG_LOGS=false
ARG RIVET_PUBLISHED_WORKFLOWS_BASE_PATH=/workflows
ARG RIVET_LATEST_WORKFLOWS_BASE_PATH=/workflows-latest
ARG RIVET_WEB_BUILD_MAX_OLD_SPACE_SIZE=4096
ENV VITE_RIVET_DEBUG_LOGS=$VITE_RIVET_DEBUG_LOGS
ENV RIVET_PUBLISHED_WORKFLOWS_BASE_PATH=$RIVET_PUBLISHED_WORKFLOWS_BASE_PATH
ENV RIVET_LATEST_WORKFLOWS_BASE_PATH=$RIVET_LATEST_WORKFLOWS_BASE_PATH
RUN NODE_OPTIONS="--max-old-space-size=${RIVET_WEB_BUILD_MAX_OLD_SPACE_SIZE}" npx vite build --config vite.config.ts

# --- Production stage ---
FROM --platform=$BUILDPLATFORM ${NODE_IMAGE} AS serve-installer

RUN npm install -g serve

FROM --platform=$TARGETPLATFORM ${NODE_IMAGE}

ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG ALL_PROXY
ARG NO_PROXY
ARG http_proxy
ARG https_proxy
ARG all_proxy
ARG no_proxy

ENV HTTP_PROXY=$HTTP_PROXY
ENV HTTPS_PROXY=$HTTPS_PROXY
ENV ALL_PROXY=$ALL_PROXY
ENV NO_PROXY=$NO_PROXY
ENV http_proxy=$http_proxy
ENV https_proxy=$https_proxy
ENV all_proxy=$all_proxy
ENV no_proxy=$no_proxy

WORKDIR /app
COPY --from=serve-installer /usr/local/lib/node_modules/serve /usr/local/lib/node_modules/serve
COPY --from=builder /app/wrapper/web/dist ./dist

EXPOSE 3000
CMD ["node", "/usr/local/lib/node_modules/serve/build/main.js", "-s", "dist", "-l", "3000"]
