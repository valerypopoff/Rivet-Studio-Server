map_hash_bucket_size 128;

map $http_upgrade $connection_upgrade {
    default upgrade;
    '' close;
}

map $host $rivet_ui_host_is_token_free {
    default 0;
    ~${RIVET_UI_TOKEN_FREE_HOSTS_REGEX} 1;
}

map $cookie_rivet_ui_token $rivet_ui_has_valid_cookie_token {
    default 0;
    "${RIVET_UI_SESSION_TOKEN}" 1;
}

map $scheme $rivet_ui_cookie_secure_suffix {
    default "";
    https "; Secure";
}

map "${RIVET_REQUIRE_UI_GATE_KEY}" $rivet_ui_gate_enabled {
    default 0;
    "1" 1;
}

map "${RIVET_UI_GATE_KEY_PRESENT}" $rivet_ui_gate_has_key {
    default 0;
    "1" 1;
}

map "$rivet_ui_gate_enabled:$rivet_ui_gate_has_key:$rivet_ui_host_is_token_free:$rivet_ui_has_valid_cookie_token" $rivet_ui_gate_result {
    default allow;
    "1:0:0:0" deny;
    "1:0:0:1" deny;
    "1:0:1:0" allow;
    "1:0:1:1" allow;
    "1:1:0:0" deny;
    "1:1:0:1" allow;
    "1:1:1:0" allow;
    "1:1:1:1" allow;
}

server {
    listen 80;
    server_name _;

    client_max_body_size 100m;

    location / {
        if ($rivet_ui_gate_result = deny) {
            return 401;
        }

        if ($rivet_ui_gate_result = allow_with_cookie) {
            return 418;
        }

        proxy_pass http://web:5174;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    location @web_with_token_cookie {
        add_header Set-Cookie "rivet_ui_token=${RIVET_UI_SESSION_TOKEN}; Path=/; HttpOnly; SameSite=Lax$rivet_ui_cookie_secure_suffix" always;
        proxy_pass http://web:5174;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    location @web_with_ui_gate_prompt {
        internal;
        default_type text/html;
        add_header Cache-Control "no-store, no-cache, must-revalidate" always;
        add_header Pragma "no-cache" always;
        root /tmp/nginx/html;
        try_files /ui-gate-prompt.html =500;
    }

    location = /__rivet_auth {
        proxy_pass http://api/ui-auth;
        proxy_http_version 1.1;
        proxy_set_header X-Rivet-Proxy-Auth ${RIVET_PROXY_AUTH_TOKEN};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }

    location /api/ {
        if ($rivet_ui_gate_result = deny) {
            return 403;
        }

        proxy_pass http://api;
        proxy_http_version 1.1;
        proxy_set_header X-Rivet-Proxy-Auth ${RIVET_PROXY_AUTH_TOKEN};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout ${RIVET_PROXY_READ_TIMEOUT};
        proxy_send_timeout ${RIVET_PROXY_READ_TIMEOUT};
    }

    location ${RIVET_PUBLISHED_WORKFLOWS_BASE_PATH}/ {
        proxy_pass http://api;
        proxy_http_version 1.1;
        proxy_set_header X-Rivet-Proxy-Auth ${RIVET_PROXY_AUTH_TOKEN};
        proxy_set_header X-Rivet-Token-Free-Host $rivet_ui_host_is_token_free;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout ${RIVET_PROXY_READ_TIMEOUT};
        proxy_send_timeout ${RIVET_PROXY_READ_TIMEOUT};
    }

    location ${RIVET_LATEST_WORKFLOWS_BASE_PATH}/ {
        proxy_pass http://api;
        proxy_http_version 1.1;
        proxy_set_header X-Rivet-Proxy-Auth ${RIVET_PROXY_AUTH_TOKEN};
        proxy_set_header X-Rivet-Token-Free-Host $rivet_ui_host_is_token_free;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout ${RIVET_PROXY_READ_TIMEOUT};
        proxy_send_timeout ${RIVET_PROXY_READ_TIMEOUT};
    }

    location /ws/latest-debugger {
        if ($rivet_ui_gate_result = deny) {
            return 403;
        }

        proxy_pass http://api/ws/latest-debugger;
        proxy_http_version 1.1;
        proxy_set_header X-Rivet-Proxy-Auth ${RIVET_PROXY_AUTH_TOKEN};
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400s;
    }

    location /ws/executor/internal {
        if ($rivet_ui_gate_result = deny) {
            return 403;
        }

        proxy_pass http://executor:21889/internal;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400s;
    }

    location /ws/executor {
        if ($rivet_ui_gate_result = deny) {
            return 403;
        }

        proxy_pass http://executor:21889/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400s;
    }

    error_page 401 = @web_with_ui_gate_prompt;
    error_page 418 = @web_with_token_cookie;
}
