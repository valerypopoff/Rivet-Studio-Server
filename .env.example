# Docker compose
RIVET_PORT=8080

# Fast deploys can pull prebuilt images from GHCR with `npm run prod:prebuilt`.
# Leave these unset to use the default published images and the `latest` tag.
# RIVET_IMAGE_TAG=latest
# RIVET_WEB_IMAGE=ghcr.io/valerypopoff/cloud-hosted-rivet-wrapper/web:latest
# RIVET_API_IMAGE=ghcr.io/valerypopoff/cloud-hosted-rivet-wrapper/api:latest
# RIVET_EXECUTOR_IMAGE=ghcr.io/valerypopoff/cloud-hosted-rivet-wrapper/executor:latest


# Filesystem artifact root
#
# Canonical local-filesystem contract:
# - set RIVET_STORAGE_MODE=filesystem
# - point RIVET_ARTIFACTS_HOST_PATH at a shared host root
# - the launchers derive:
#   - <root>/workflows
#   - <root>/workflow-recordings
#   - <root>/runtime-libraries
RIVET_ARTIFACTS_HOST_PATH=../
# Optional explicit override for the API recordings bind mount in Docker modes.
# If unset, the launcher derives <RIVET_ARTIFACTS_HOST_PATH>/workflow-recordings when
# RIVET_ARTIFACTS_HOST_PATH is present.
# RIVET_WORKFLOW_RECORDINGS_HOST_PATH=

# Artifact storage backend
# filesystem = current host-folder behavior
# managed = Postgres + S3-compatible object storage
RIVET_STORAGE_MODE=filesystem

# Managed shared-state services
#
# local-docker = use the optional Docker Compose Postgres/MinIO services
# managed = use external managed services such as RDS + S3-compatible storage
RIVET_DATABASE_MODE=local-docker
# For the Docker stacks, use the compose service names below when managed mode is enabled.
# For host-run API/testing, point these at the corresponding host ports instead.
# RIVET_DATABASE_CONNECTION_STRING=postgres://rivet:rivet@workflow-postgres:5432/rivet
# RIVET_DATABASE_SSL_MODE=disable
# Recommended URL form:
# RIVET_STORAGE_URL=http://workflow-minio:9000/rivet-workflows
# RIVET_STORAGE_ACCESS_KEY_ID=minioadmin
# RIVET_STORAGE_ACCESS_KEY=minioadmin
#
# Optional explicit S3 tuple form:
# RIVET_STORAGE_BUCKET=rivet-workflows
# RIVET_STORAGE_REGION=us-east-1
# RIVET_STORAGE_ENDPOINT=http://workflow-minio:9000
# RIVET_STORAGE_ACCESS_KEY_ID=minioadmin
# RIVET_STORAGE_ACCESS_KEY=minioadmin
# RIVET_STORAGE_PREFIX=workflows/
# RIVET_STORAGE_FORCE_PATH_STYLE=true
#
# SSL mode is controlled by RIVET_DATABASE_SSL_MODE.
# The app defaults to disable for local-docker and require for managed.
# Connection-string sslmode query parameters are ignored by the app.

# Local Kubernetes rehearsal launcher
#
# `npm run dev:kubernetes-test` expects the supported Kubernetes shape:
# - RIVET_STORAGE_MODE=managed
# - RIVET_DATABASE_MODE=managed
# - real external Postgres + S3-compatible storage
#
# Use `npm run verify:kubernetes` for the repo-local render/lint check that covers both the
# local rehearsal values path and the production overlay contract.
#
# Required managed-service inputs for that launcher:
# RIVET_DATABASE_CONNECTION_STRING=postgresql://db-user:db-pass@example-db:5432/rivet?sslmode=require
# RIVET_STORAGE_URL=https://my-bucket.s3.us-east-1.amazonaws.com
# or the explicit tuple below:
# RIVET_STORAGE_BUCKET=my-bucket
# RIVET_STORAGE_REGION=us-east-1
# RIVET_STORAGE_ENDPOINT=
# RIVET_STORAGE_ACCESS_KEY_ID=
# RIVET_STORAGE_ACCESS_KEY=
# RIVET_STORAGE_FORCE_PATH_STYLE=false
#
# Optional launcher-only overrides:
# RIVET_K8S_CONTEXT=minikube
# RIVET_K8S_CLUSTER_PROVIDER=minikube
# RIVET_K8S_MINIKUBE_PROFILE=minikube
# RIVET_K8S_MINIKUBE_BIN=minikube
# RIVET_K8S_CLUSTER_DOMAIN=cluster.local
# RIVET_K8S_NAMESPACE=rivet-local
# RIVET_K8S_RELEASE=rivet-local
# RIVET_K8S_PROXY_PORT=8080
# RIVET_PROXY_RESOLVER may be a Kubernetes DNS service hostname; the proxy entrypoint resolves it to IPs before nginx starts.
# RIVET_K8S_PROXY_REPLICAS=2
# RIVET_K8S_WEB_REPLICAS=1
# RIVET_K8S_EXECUTION_REPLICAS=2
# RIVET_K8S_LOAD_LOCAL_IMAGES=true

## Optional local-docker managed-service defaults used by the Docker stacks
# RIVET_WORKFLOWS_LOCAL_DOCKER_POSTGRES_DB=rivet
# RIVET_WORKFLOWS_LOCAL_DOCKER_POSTGRES_USER=rivet
# RIVET_WORKFLOWS_LOCAL_DOCKER_POSTGRES_PASSWORD=rivet
# RIVET_WORKFLOWS_LOCAL_DOCKER_POSTGRES_PORT=54329
# RIVET_WORKFLOWS_LOCAL_DOCKER_OBJECT_STORAGE_BUCKET=rivet-workflows
# RIVET_WORKFLOWS_LOCAL_DOCKER_OBJECT_STORAGE_ACCESS_KEY_ID=minioadmin
# RIVET_WORKFLOWS_LOCAL_DOCKER_OBJECT_STORAGE_SECRET_ACCESS_KEY=minioadmin
# RIVET_WORKFLOWS_LOCAL_DOCKER_OBJECT_STORAGE_PORT=9000
# RIVET_WORKFLOWS_LOCAL_DOCKER_OBJECT_STORAGE_CONSOLE_PORT=9001

# Runtime-library sync behavior in managed mode
#
# Runtime libraries follow RIVET_STORAGE_MODE:
# - filesystem: local runtime-libraries/ under RIVET_ARTIFACTS_HOST_PATH
# - managed:    Postgres + object storage, with immutable artifacts under runtime-libraries/
# Optional poll interval for background reconciliation in managed mode:
# RIVET_RUNTIME_LIBRARIES_SYNC_POLL_INTERVAL_MS=5000
# Optional stale-replica retention and cleanup cadence for replica-readiness reporting.
# Defaults:
# - local-docker: retain stale rows for 24h, clean every 15m
# - managed: retain stale rows for 15m, clean every 5m
# RIVET_RUNTIME_LIBRARIES_REPLICA_STATUS_RETENTION_MS=900000
# RIVET_RUNTIME_LIBRARIES_REPLICA_STATUS_CLEANUP_INTERVAL_MS=300000
# Optional explicit process role for managed replica-readiness reporting.
# The official API/executor images and compose stacks set this automatically.
# RIVET_RUNTIME_PROCESS_ROLE=api

# Filesystem recording storage
#
# In filesystem mode:
# - live projects and .published snapshots stay under RIVET_WORKFLOWS_ROOT
# - recording bundles may be split onto a separate root with RIVET_WORKFLOW_RECORDINGS_ROOT
# - recordings.sqlite stays under RIVET_APP_DATA_ROOT
#
# Docker stacks set RIVET_WORKFLOW_RECORDINGS_ROOT=/workflow-recordings automatically.
# Host migration example:
#   New-Item -ItemType Directory -Force D:\Programming\workflow-recordings
#   robocopy D:\Programming\workflows\.recordings D:\Programming\workflow-recordings /E /MOVE
# RIVET_WORKFLOW_RECORDINGS_ROOT=



# Security settings
## Whether workflow execution endpoints require Authorization: Bearer <RIVET_KEY>
RIVET_REQUIRE_WORKFLOW_KEY=false

## Whether the browser UI token gate is enabled ?token=<RIVET_KEY>
RIVET_REQUIRE_UI_GATE_KEY=false

## Shared key for workflow execution (as bearer token) and for UI token gate
RIVET_KEY=

## Hosts that always bypass the token check in the UI gate and workflow execution routes
RIVET_UI_TOKEN_FREE_HOSTS=



# Workflow execution paths
RIVET_PUBLISHED_WORKFLOWS_BASE_PATH=/workflows
RIVET_LATEST_WORKFLOWS_BASE_PATH=/workflows-latest



# Remote debugger
RIVET_ENABLE_LATEST_REMOTE_DEBUGGER=true

## Runtime websocket defaults are derived from the incoming request host unless overridden.
## RIVET_EXECUTOR_WS_URL=
## RIVET_REMOTE_DEBUGGER_DEFAULT_WS=



VITE_RIVET_DEBUG_LOGS=false
RIVET_WEB_BUILD_MAX_OLD_SPACE_SIZE=4096
# Browser clients should use the proxy-relative API route.
VITE_RIVET_API_BASE_URL=/api

# API ports
# Host port exposed by the Docker dev stack.
# Docker maps this host port to port 80 inside the API container.
RIVET_API_PORT=3100

# Port used when running the API service directly outside Docker.
# In Docker, compose overrides this to PORT=80 inside the container.
PORT=3100

# API service
# Optional overrides. Leave unset to use self-contained defaults:
# - workspace root -> repo root
# - app data root  -> <repo>/.data/rivet-app
# RIVET_WORKSPACE_ROOT=
# RIVET_APP_DATA_ROOT=

# Optional extra env vars that the hosted UI/API bridge may read via /api/config/env/:name.
# Default allowlist already includes OPENAI_API_KEY, OPENAI_ORG_ID, and OPENAI_ENDPOINT.
# RIVET_ENV_ALLOWLIST=

# Optional extra shell programs the hosted API may execute.
# Default allowlist already includes git and pnpm.
# RIVET_SHELL_ALLOWLIST=

# Optional extra filesystem roots the hosted API may access.
# Use this to allow file operations outside the workspace, app data, and workflows roots.
# Provide a comma-separated list of absolute paths, for example:
# RIVET_EXTRA_ROOTS=D:\SharedAssets,D:\ModelFiles

RIVET_COMMAND_TIMEOUT=30000
RIVET_MAX_OUTPUT=10485760
RIVET_DOCKER_WAIT_TIMEOUT=1200

# Optional OpenAI values surfaced via hosted env shim
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_ENDPOINT=
