        '[MDuVIoQYuHlno49ygev9h]:code "Code"':
          data:
            allowConsole: false
            allowFetch: false
            allowProcess: false
            allowRequire: false
            allowRivet: false
            code: >-
              function buildThreadTexts(payload) {
                const { story, thread } = payload;
                const messages = thread?.messages || [];
                const userCharacterId = thread?.characterId;

                // Build lookup for all known characters
                const characterMap = new Map();

                for (const ch of story?.characters || []) {
                  characterMap.set(ch.id, ch.name);
                }

                for (const ch of thread?.npcCharacters || []) {
                  characterMap.set(ch.id, ch.name);
                }

                const formatMessage = (msg) => {
                  const characterId = msg.characterId;
                  const name = characterMap.get(characterId) || "Unknown character";
                  const text = msg?.payload?.text ?? "";
                  return `${name} (id: ${characterId}): ${text}`;
                };

                // Find the last message from the user's selected character
                let lastUserMessageIndex = -1;
                for (let i = messages.length - 1; i >= 0; i--) {
                  if (messages[i].characterId === userCharacterId) {
                    lastUserMessageIndex = i;
                    break;
                  }
                }

                const userMessage =
                  lastUserMessageIndex >= 0 ? formatMessage(messages[lastUserMessageIndex]) : "";

                const otherMessages = messages
                  .filter((_, index) => index !== lastUserMessageIndex)
                  .map(formatMessage)
                  .join("\n\n");

                return {
                  userMessage,
                  otherMessages,
                };
              }


              //=================================================


              const payload = inputs.payload.value

              const messages = buildThreadTexts(payload)


              return {
                userMessage: {
                  type: typeof(""),
                  value: messages.userMessage
                },
                otherMessages: {
                  type: typeof(""),
                  value: messages.otherMessages
                }
              };
            inputNames:
              - payload
            outputNames:
              - userMessage
              - otherMessages
          outgoingConnections:
            - otherMessages->"Graph Output" 20m5e65NCa2FnXlmI8jSy/value
            - userMessage->"Graph Output" I-j7x6aMoMs1rhBLBIQpi/value
