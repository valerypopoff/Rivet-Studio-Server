            code: >-
              function getCurrentAndNextStage(data) {
                const stages = data?.story?.plot?.stages ?? [];
                const statuses = data?.thread?.plotStageStatuses ?? [];

                if (!stages.length || !statuses.length) {
                  return { currentStage: null, nextStage: null };
                }

                // Find current stage index from thread statuses
                const currentIndex = statuses.findIndex(
                  (s) => s.status === "inProgress"
                );

                if (currentIndex === -1 || currentIndex >= stages.length) {
                  return { currentStage: null, nextStage: null };
                }

                const currentStageID = statuses[currentIndex].id

                return {
                  currentStage: stages[currentIndex] ?? null,
                  nextStage: stages[currentIndex + 1] ?? null,
                  currentStageID: currentStageID
                };
              }


              const payload = inputs.payload.value

              const stages = getCurrentAndNextStage(payload)


              return {
                currentStage: {
                  type: typeof(""),
                  value: [stages.currentStage].map( e => `Name: ${e.name}\nDescription: ${e.description}` ).join("\n\n")
                },
                nextStage: {
                  type: typeof(""),
                  value: [stages.nextStage].map( e => `Name: ${e.name}\nDescription: ${e.description}` ).join("\n\n")
                },
                allStages: {
                  type: typeof(""),
                  value: (payload?.story?.plot?.stages || []).map( e => `Name: ${e.name}\nDescription: ${e.description}` ).join("\n\n")
                },
                currentStageID: {
                  type: typeof(""),
                  value: stages.currentStageID
                }
              };
