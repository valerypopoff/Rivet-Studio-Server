            code: >-
              function formatCharacters(payload, ignoredFields = []) {
                const { story, thread } = payload || {};

                if (!story || !thread) {
                  throw new Error("Invalid payload: story and thread are required.");
                }

                const ignore = new Set(ignoredFields);
                const playerCharacterId = thread.characterId;

                const storyCharacters = Array.isArray(story.characters) ? story.characters : [];
                const npcCharacters = Array.isArray(thread.npcCharacters) ? thread.npcCharacters : [];
                const allCharacters = [...storyCharacters, ...npcCharacters];

                const playerCharacter = allCharacters.find((char) => char.id === playerCharacterId);

                if (!playerCharacter) {
                  throw new Error(`Player character not found: ${playerCharacterId}`);
                }

                const otherCharacters = allCharacters.filter((char) => char.id !== playerCharacterId);

                function formatObject(obj, level = 0) {
                  return Object.entries(obj)
                    .filter(([key]) => key !== "name" && !ignore.has(key))
                    .map(([key, value]) => {
                      const indent = "  ".repeat(level);

                      // Special handling: print only description for archetype and gender
                      if (
                        (key === "archetype" || key === "gender") &&
                        value &&
                        typeof value === "object" &&
                        "description" in value
                      ) {
                        return `${indent}${key}: ${value.description}`;
                      }

                      if (Array.isArray(value)) {
                        if (value.length === 0) {
                          return `${indent}${key}: []`;
                        }

                        const items = value
                          .map((item) => {
                            if (item && typeof item === "object") {
                              return `${indent}  -\n${formatObject(item, level + 2)}`;
                            }
                            return `${indent}  - ${String(item)}`;
                          })
                          .join("\n");

                        return `${indent}${key}:\n${items}`;
                      }

                      if (value && typeof value === "object") {
                        return `${indent}${key}:\n${formatObject(value, level + 1)}`;
                      }

                      return `${indent}${key}: ${String(value)}`;
                    })
                    .join("\n");
                }

                function formatCharacter(character) {
                  const header = `#### ${character.name || "Unknown character"}`;
                  const body = formatObject(character);
                  return body ? `${header}\n${body}` : header;
                }

                return {
                  playerCharacter: formatCharacter(playerCharacter),
                  otherCharacters: otherCharacters.map(formatCharacter).join("\n\n")
                };
              }


              // ======================================



              const payload = inputs.payload.value

              const characters = formatCharacters(payload, ["image",
              "isPlayable", "initialMessage", "initialChoices", "role"])

