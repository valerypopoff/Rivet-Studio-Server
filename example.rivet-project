        '[2r6MGriPzIS8-lyLn0poJ]:code "Code - Reformat messages"':
          data:
            allowConsole: false
            allowFetch: false
            allowProcess: false
            allowRequire: false
            allowRivet: false
            code: |-
              function transformStoryPayload(input) {
                return {
                  ...input,
                  messages: (input.messages || []).map((msg) => ({
                    characterId: msg.characterID,
                    type: "text",
                    payload: {
                      text: msg.text,
                    },
                  })),
                };
              }

              let payload = inputs.input.value

              payload = transformStoryPayload(payload)

              return {
                output: {
                  type: inputs.input.type,
                  value: payload
                }
              };
            inputNames:
              - input
            outputNames:
              - output
          outgoingConnections:
