{
  "name": "rivet-studio-server",
  "private": true,
  "version": "1.0.0",
  "description": "Root launcher for the Rivet Studio Server Docker stacks",
  "scripts": {
    "setup": "node scripts/ensure-dev-deps.mjs",
    "setup:rivet": "node scripts/bootstrap-rivet.mjs",
    "runtime-libraries:managed:audit": "node scripts/run-with-env.mjs \"npm --prefix wrapper/api run runtime-libraries:managed:audit\"",
    "runtime-libraries:managed:prune": "node scripts/run-with-env.mjs \"npm --prefix wrapper/api run runtime-libraries:managed:prune --\"",
    "workflow-storage:migrate": "node scripts/run-with-env.mjs \"npm --prefix wrapper/api run workflow-storage:migrate\"",
    "workflow-storage:verify": "node scripts/run-with-env.mjs \"npm --prefix wrapper/api run workflow-storage:verify\"",
    "workflow-storage:dangerously-nuke-managed-state": "node scripts/run-with-env.mjs \"npm --prefix wrapper/api run workflow-storage:dangerously-nuke-managed-state --\"",
    "verify:filesystem": "node scripts/verify-compatibility.mjs filesystem",
    "verify:filesystem:docker": "node scripts/verify-compatibility.mjs filesystem:docker",
    "verify:local-docker": "node scripts/verify-compatibility.mjs local-docker",
    "verify:local-docker:split": "node scripts/verify-compatibility.mjs local-docker:split",
    "verify:web-pure": "npx tsx --test wrapper/web/tests/api-request.test.ts wrapper/web/tests/remote-execution-session.test.ts wrapper/web/tests/remote-executor-protocol.test.ts",
    "verify:kubernetes": "npx tsx --test wrapper/api/src/tests/kubernetes-launcher-config.test.ts wrapper/api/src/tests/phase4-static-contract.test.ts && node scripts/verify-kubernetes.mjs",
    "ui:observe": "node scripts/playwright-observe.mjs test",
    "ui:observe:debug": "node scripts/playwright-observe.mjs debug",
    "ui:observe:install": "node scripts/playwright-observe.mjs install",
    "ui:observe:report": "node scripts/playwright-observe.mjs report",
    "prod": "node scripts/prod-docker.mjs auto",
    "prod:prebuilt": "node scripts/prod-docker.mjs prod-prebuilt",
    "prod:prebuilt:recreate": "node scripts/prod-docker.mjs recreate-prebuilt",
    "prod:local-build": "npm run prod:docker",
    "prod:docker": "node scripts/prod-docker.mjs prod",
    "prod:docker:recreate": "node scripts/prod-docker.mjs recreate",
    "prod:docker:build": "node scripts/prod-docker.mjs build",
    "prod:docker:up": "node scripts/prod-docker.mjs up",
    "prod:docker:down": "node scripts/prod-docker.mjs down",
    "prod:docker:config": "node scripts/prod-docker.mjs config",
    "prod:docker:ps": "node scripts/prod-docker.mjs ps",
    "prod:docker:logs": "node scripts/prod-docker.mjs logs",
    "prod:down": "npm run prod:docker:down",
    "prod:recreate": "npm run prod:docker:recreate",
    "dev": "npm run dev:docker",
    "dev:docker": "node scripts/dev-docker.mjs dev",
    "dev:docker:recreate": "node scripts/dev-docker.mjs recreate",
    "dev:docker:build": "node scripts/dev-docker.mjs build",
    "dev:docker:up": "node scripts/dev-docker.mjs up",
    "dev:docker:down": "node scripts/dev-docker.mjs down",
    "dev:docker:config": "node scripts/dev-docker.mjs config",
    "dev:docker:ps": "node scripts/dev-docker.mjs ps",
    "dev:docker:logs": "node scripts/dev-docker.mjs logs",
    "dev:down": "npm run dev:docker:down",
    "dev:recreate": "npm run dev:docker:recreate",
    "predev:kubernetes-test": "node scripts/ensure-dev-deps.mjs",
    "predev:kubernetes-test:recreate": "node scripts/ensure-dev-deps.mjs",
    "predev:kubernetes-test:build": "node scripts/ensure-dev-deps.mjs",
    "dev:kubernetes-test": "node scripts/dev-kubernetes.mjs dev",
    "dev:kubernetes-test:recreate": "node scripts/dev-kubernetes.mjs recreate",
    "dev:kubernetes-test:build": "node scripts/dev-kubernetes.mjs build",
    "dev:kubernetes-test:up": "node scripts/dev-kubernetes.mjs up",
    "dev:kubernetes-test:down": "node scripts/dev-kubernetes.mjs down",
    "dev:kubernetes-test:config": "node scripts/dev-kubernetes.mjs config",
    "dev:kubernetes-test:ps": "node scripts/dev-kubernetes.mjs ps",
    "dev:kubernetes-test:logs": "node scripts/dev-kubernetes.mjs logs",
    "dev:local": "node scripts/dev.mjs",
    "predev:local": "node scripts/ensure-dev-deps.mjs",
    "dev:local:api": "node scripts/run-with-env.mjs \"npm --prefix wrapper/api run dev\"",
    "dev:local:web": "node scripts/run-with-env.mjs \"npm --prefix wrapper/web run dev\"",
    "dev:local:executor": "node scripts/run-with-env.mjs \"corepack yarn --cwd rivet workspace @ironclad/rivet-app-executor run dev\""
  },
  "packageManager": "yarn@3.5.0+sha512.2dc70be5fce9f66756d25b00a888f3ca66f86b502b76750e72ba54cec89da767b938c54124595e26f868825688e0fe3552c26c76a330673343057acadd5cfcf2"
}
