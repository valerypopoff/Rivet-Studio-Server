{
  "name": "rivet-studio-server",
  "private": true,
  "version": "1.0.0",
  "description": "Root launcher for the Rivet Studio Server Docker stacks",
  "scripts": {
    "setup": "node scripts/ensure-dev-deps.mjs",
    "setup:rivet": "node scripts/bootstrap-rivet.mjs",
    "prod": "npm run prod:docker",
    "prod:local": "npm run prod:docker",
    "prod:fast": "node scripts/prod-docker.mjs prod-prebuilt",
    "prod:fast:recreate": "node scripts/prod-docker.mjs recreate-prebuilt",
    "prod:docker": "node scripts/prod-docker.mjs prod",
    "prod:docker:recreate": "node scripts/prod-docker.mjs recreate",
    "prod:docker:build": "node scripts/prod-docker.mjs build",
    "prod:docker:up": "node scripts/prod-docker.mjs up",
    "prod:docker:down": "node scripts/prod-docker.mjs down",
    "prod:docker:config": "node scripts/prod-docker.mjs config",
    "prod:docker:ps": "node scripts/prod-docker.mjs ps",
    "prod:docker:logs": "node scripts/prod-docker.mjs logs",
    "prod:down": "npm run prod:docker:down",
    "prod:recreate": "npm run prod:docker:recreate",
    "dev": "npm run dev:docker",
    "dev:docker": "node scripts/dev-docker.mjs dev",
    "dev:docker:recreate": "node scripts/dev-docker.mjs recreate",
    "dev:docker:build": "node scripts/dev-docker.mjs build",
    "dev:docker:up": "node scripts/dev-docker.mjs up",
    "dev:docker:down": "node scripts/dev-docker.mjs down",
    "dev:docker:config": "node scripts/dev-docker.mjs config",
    "dev:docker:ps": "node scripts/dev-docker.mjs ps",
    "dev:docker:logs": "node scripts/dev-docker.mjs logs",
    "dev:down": "npm run dev:docker:down",
    "dev:recreate": "npm run dev:docker:recreate",
    "dev:local": "node scripts/dev.mjs",
    "predev:local": "node scripts/ensure-dev-deps.mjs",
    "dev:local:api": "node scripts/run-with-env.mjs \"npm --prefix wrapper/api run dev\"",
    "dev:local:web": "node scripts/run-with-env.mjs \"npm --prefix wrapper/web run dev\"",
    "dev:local:executor": "node scripts/run-with-env.mjs \"corepack yarn --cwd rivet workspace @ironclad/rivet-app-executor run dev\""
  },
  "packageManager": "yarn@3.5.0+sha512.2dc70be5fce9f66756d25b00a888f3ca66f86b502b76750e72ba54cec89da767b938c54124595e26f868825688e0fe3552c26c76a330673343057acadd5cfcf2"
}
